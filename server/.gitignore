# .NET build outputs
bin/
obj/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Environment-specific appsettings (may contain secrets)
appsettings.Development.json
appsettings.Production.json
appsettings.Local.json

# Runtime data directory (database, JWT secret, page cache)
# Created automatically when the server runs — never commit.
data/

# Auto-generated JWT secret (written to DataPath on first launch)
*.key

# Release bundles (build artifacts, not source)
Releases/

# NuGet
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
packages/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml
